@using MVC_Day2.Models.ViewModels


@model GetTraineeCoursesViewModelcs;


@{
    ViewData["Title"] = "GetCourses";
}

<h1>GetCourses</h1>


@for (int i = 0; i < Model.CourseName.Count; i++)
{  
<div style="color:@Model.status[i]">

        <p>Course Name: @Model.CourseName[i]</p>
        <p>Degree: @Model.Degree[i]</p>

</div>
}

