@model LoginViewModel
@{
    ViewData["Title"] = "LogIn";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap');

    .login-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: stretch;
        margin: -20px;
        font-family: 'DM Sans', sans-serif;
    }

    .login-left {
        flex: 1;
        background: #0f0f0f;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 60px;
        position: relative;
        overflow: hidden;
    }

        .login-left::before {
            content: '';
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(99,60,180,0.25) 0%, transparent 70%);
            top: -100px;
            left: -100px;
            pointer-events: none;
        }

        .login-left::after {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(29,158,117,0.15) 0%, transparent 70%);
            bottom: -80px;
            right: -80px;
            pointer-events: none;
        }

    .brand-logo {
        font-family: 'Playfair Display', serif;
        font-size: 2.8rem;
        color: #ffffff;
        letter-spacing: -1px;
        margin-bottom: 12px;
        position: relative;
        z-index: 1;
    }

        .brand-logo span {
            color: #1D9E75;
        }

    .brand-tagline {
        font-size: 0.95rem;
        color: rgba(255,255,255,0.4);
        letter-spacing: 3px;
        text-transform: uppercase;
        position: relative;
        z-index: 1;
    }

    .decorative-line {
        width: 60px;
        height: 1px;
        background: linear-gradient(90deg, #1D9E75, transparent);
        margin: 40px auto;
        position: relative;
        z-index: 1;
    }

    .left-quote {
        font-family: 'Playfair Display', serif;
        font-size: 1.3rem;
        color: rgba(255,255,255,0.6);
        text-align: center;
        line-height: 1.8;
        max-width: 320px;
        font-style: italic;
        position: relative;
        z-index: 1;
    }

    .login-right {
        flex: 1;
        background: #ffffff;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 60px 80px;
    }

    .login-heading {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        color: #0f0f0f;
        margin-bottom: 6px;
        font-weight: 700;
    }

    .login-subheading {
        font-size: 0.9rem;
        color: #888780;
        margin-bottom: 40px;
        letter-spacing: 0.3px;
    }

        .login-subheading a {
            color: #1D9E75;
            text-decoration: none;
            font-weight: 500;
        }

    .form-group {
        margin-bottom: 24px;
    }

        .form-group label {
            display: block;
            font-size: 0.8rem;
            font-weight: 500;
            color: #444441;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .form-group input[type="text"],
        .form-group input[type="password"] {
            width: 100%;
            padding: 14px 18px;
            border: 1.5px solid #e8e8e8;
            border-radius: 10px;
            font-size: 0.95rem;
            font-family: 'DM Sans', sans-serif;
            color: #0f0f0f;
            background: #fafafa;
            transition: all 0.2s ease;
            box-sizing: border-box;
            outline: none;
        }

            .form-group input[type="text"]:focus,
            .form-group input[type="password"]:focus {
                border-color: #1D9E75;
                background: #ffffff;
                box-shadow: 0 0 0 4px rgba(29,158,117,0.08);
            }

    .remember-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 32px;
    }

    .remember-check {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }

        .remember-check input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: #1D9E75;
            cursor: pointer;
        }

        .remember-check span {
            font-size: 0.88rem;
            color: #5F5E5A;
        }

    .btn-login {
        width: 100%;
        padding: 16px;
        background: #0f0f0f;
        color: #ffffff;
        border: none;
        border-radius: 10px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.95rem;
        font-weight: 500;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.25s ease;
        text-transform: uppercase;
    }

        .btn-login:hover {
            background: #1D9E75;
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(29,158,117,0.25);
        }

        .btn-login:active {
            transform: translateY(0);
        }

    .validation-error {
        background: #FCEBEB;
        border-left: 3px solid #E24B4A;
        border-radius: 8px;
        padding: 12px 16px;
        margin-bottom: 24px;
        font-size: 0.87rem;
        color: #A32D2D;
    }

    .field-error {
        font-size: 0.8rem;
        color: #E24B4A;
        margin-top: 6px;
        display: block;
    }

    @@media (max-width: 768px) {
        .login-left {
            display: none;
        }

        .login-right {
            padding: 40px 30px;
        }

        .login-wrapper {
            margin: -20px;
        }
    }
</style>

<div class="login-wrapper">
    <div class="login-left">
        <div class="brand-logo">MVC<span>.</span></div>
        <div class="brand-tagline">Your Learning Platform</div>
        <div class="decorative-line"></div>
        <p class="left-quote">"Education is the passport to the future, for tomorrow belongs to those who prepare for it today."</p>
    </div>

    <div class="login-right">
        <h1 class="login-heading">Welcome back.</h1>
        <p class="login-subheading">
            Don't have an account?
            <a asp-controller="Account" asp-action="Register">Create one</a>
        </p>

        <form asp-action="Logged" asp-controller="Account" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-error"></div>

            <div class="form-group">
                <label asp-for="UserName">Username</label>
                <input asp-for="UserName" type="text" placeholder="Enter your username" />
                <span asp-validation-for="UserName" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" type="password" placeholder="••••••••" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="remember-row">
                <label class="remember-check">
                    <input asp-for="RememberMe" type="checkbox" />
                    <span>Remember me</span>
                </label>
            </div>

            <button type="submit" class="btn-login">Sign In</button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
