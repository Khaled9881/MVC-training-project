@model List<Instructor>


@{
    ViewData["Title"] = "GetAllInstructors";
}

<h1>GetAllInstructors</h1>



<table class="table table-striped table-hover" >

    <thead>
        <th>Id</th>
        <th>Name</th>
        <th>Image</th>
        <th>Salary</th>
        <th>Address</th>
        <th>Link</th>
    </thead>

    @foreach(var item in Model)
    {
        <tr>

            <td>@item.Id</td>
            <td>@item.Name</td>
            <td class="w-25">
                <img src="@item.Image" alt="Alternate Text" class="img-fluid object-fit-contain w-25 h-25"  />
            </td>
            <td>@item.Salary</td>
            <td>@item.Address</td>
            <td><a href="@Url.Action("Details", "Instructor", new {Id = item.Id})">
               Link 
            </a></td>
        </tr>
    }

</table>


