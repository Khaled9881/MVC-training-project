@using MVC_Day2.Models.ViewModels

@model AllInstructorsViewModel


@{
    ViewData["Title"] = "GetAllInstructors";
}

<h1>GetAllInstructors</h1>
<br />
<br />

<form action="/Instructor/Details" method="post" class="shadow d-flex justify-content-center ">
    <select class="form-select" name="id">
        <option selected>Select Instructor</option>
        @for (int i = 0; i < Model.instructors.Count; i++)
        {
            <option value="@Model.instructors[i].Id">@Model.instructors[i].Name</option>
        }
    </select>
    <button type="submit" class="btn btn-primary w-50 text-center m-auto">Choose</button>
</form>

<br />


<table class="table table-striped table-hover" >

    <thead>
        <th>Id</th>
        <th>Name</th>
        <th>Image</th>
        <th>Salary</th>
        <th>Address</th>
        <th>Course Name</th>
        <th>Department Name</th>
        <th>Link</th>
        <th>Edit</th>
        <th>Delete</th>
    </thead>

    @for (int i = 0; i < Model.instructors.Count; i++)
    {
        <tr>

            <td>@Model.instructors[i].Id</td>
            <td>@Model.instructors[i].Name</td>
            <td class="w-25">
                <img src="@Model.instructors[i].Image" alt="Alternate Text" class="img-fluid object-fit-contain w-25 h-25" />
            </td>
            <td>@Model.instructors[i].Salary</td>
            <td>@Model.instructors[i].Address</td>
            <td>@Model.CourseNames[i]</td>
            <td>@Model.DepartmentNames[i]</td>
            <td>
                <a href="@Url.Action("Details", "Instructor", new { Id = Model.instructors[i].Id })">
               View 
            </a></td>
            <td>
                <a href="@Url.Action("EditInstructor", "Instructor", new { Id = Model.instructors[i].Id })">
                    Edit
                </a>
            </td>
            <td>
                <a href="@Url.Action("DeleteInstructor", "Instructor", new { Id = Model.instructors[i].Id })">
                    Delete
                </a>
            </td>
        </tr>
    }

</table>

<div class="mt-5 mb-4">
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center mb-0">
            <!-- Previous Button -->
            <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                @if(Model.CurrentPage > 1)
                {
                    <a class="page-link" href="/Instructor/GetAllInstructors?pageNumber=@(Model.CurrentPage - 1)">
                        <i class="bi bi-chevron-left"></i> Previous
                    </a>
                }
                else
                {
                    <span class="page-link">
                        <i class="bi bi-chevron-left"></i> Previous
                    </span>
                }
            </li>

            <!-- Page Numbers -->
            @for (int i = 1; i <= Model.PagesCount; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    @if (i == Model.CurrentPage)
                    {
                        <span class="page-link">
                            @i
                            <span class="visually-hidden">(current)</span>
                        </span>
                    }
                    else
                    {
                        <a class="page-link" href="/Instructor/GetAllInstructors?pageNumber=@i">@i</a>
                    }
                </li>
            }

            <!-- Next Button -->
            <li class="page-item @(Model.CurrentPage >= Model.PagesCount ? "disabled" : "")">
                @if (Model.CurrentPage < Model.PagesCount)
                {
                    <a class="page-link" href="/Instructor/GetAllInstructors?pageNumber=@(Model.CurrentPage + 1)">
                        Next <i class="bi bi-chevron-right"></i>
                    </a>
                }
                else
                {
                    <span class="page-link">
                        Next <i class="bi bi-chevron-right"></i>
                    </span>
                }
            </li>
        </ul>
    </nav>

    <!-- Page Info -->
    <div class="text-center mt-3">
        <span class="badge bg-primary fs-6">
            Page <strong>@Model.CurrentPage</strong> of <strong>@Model.PagesCount</strong>
        </span>
    </div>
</div>

<style>
    .pagination {
        gap: 0.5rem;
    }

    .page-link {
        border-radius: 0.5rem;
        border: 1px solid #dee2e6;
        transition: all 0.3s ease;
        font-weight: 500;
    }

    .page-link:hover:not(.disabled) {
        background-color: #667eea;
        border-color: #667eea;
        color: white;
        transform: translateY(-2px);
    }

    .page-item.active .page-link {
        background-color: #667eea;
        border-color: #667eea;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }

    .page-item.disabled .page-link {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .badge {
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        box-shadow: 0 2px 8px rgba(102, 126, 234, 0.2);
    }
</style>

<br />
<br />
<br />


<form action="/Instructor/AddInstructor"  method="post" class="d-flex justify-content-center">
    <button type="submit" class="btn btn-primary w-50 text-center m-auto">Add New Instrcutor</button>
</form>

<br />
<br />
<br />
