@model Instructor
@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<table class="table table-striped table-hover">

    <thead>
        <th>Id</th>
        <th>Name</th>
        <th>Image</th>
        <th>Salary</th>
    <th>Address</th>
    <th>Home</th>
    </thead>

    <tr>

        <td>@Model.Id</td>
        <td>@Model.Name</td>
        <td class="w-25">
            <img src="@Model.Image" alt="Alternate Text" class="img-fluid object-fit-contain w-25 h-25" />
        </td>
        <td>@Model.Salary</td>
        <td>@Model.Address</td>
        <td>
            <a href="@Url.Action("GetAllInstructors", "Instructor")">
                Home
            </a>
        </td>
    </tr>

</table>
