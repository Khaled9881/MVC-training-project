@using MVC_Day2.Models.ViewModels
@model AddCourseViewModel

@{
    ViewData["Title"] = "AddCourse";
    SelectList depOptions = new SelectList(Model.departments, "Id", "Name");
    Layout = "_NewLayout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Header Card -->
            <div class="card mb-4 shadow-lg border-0">
                <div class="card-header bg-gradient"
                     style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 2rem;">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-book" style="font-size: 2.5rem; margin-right: 1rem;"></i>
                        <div>
                            <h2 class="mb-0 fw-bold">Add New Course</h2>
                            <p class="mb-0 small mt-1">Create a new course for your department</p>
                        </div>
                    </div>
                </div>

                <!-- Form Section -->
                <div class="card-body p-4">
                    <form asp-action="ADDComplete" method="post">

                        <div asp-validation-summary="All" class="text-primary"></div>

                        <!-- Course Information Section -->
                        <div class="section-divider mb-4">
                            <h5 class="fw-bold text-dark mb-3">
                                <i class="bi bi-info-circle" style="color: #667eea;"></i> Course Information
                            </h5>

                            <div class="mb-3">
                                <label asp-for="@Model.Name" class="form-label fw-semibold text-dark">Course Name</label>
                                <input type="text" asp-for="@Model.Name" class="form-control form-control-lg"
                                       placeholder="Enter the course name" required />
                                <span asp-validation-for="@Model.Name" class="text-bg-danger"></span>
                                
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label asp-for="@Model.Degree" class="form-label fw-semibold text-dark">Total Degree</label>
                                    <input type="number" asp-for="@Model.Degree" class="form-control form-control-lg" placeholder="e.g., 100" required />
                                    <span asp-validation-for="@Model.Degree" class="text-bg-danger"></span>

                                </div>
                                <div class="col-md-6">
                                    <label asp-for="@Model.MinDegree" class="form-label fw-semibold text-dark">Minimum Degree</label>
                                    <input type="number" asp-for="@Model.MinDegree" class="form-control form-control-lg" placeholder="e.g., 50" required />
                                    <span asp-validation-for="@Model.MinDegree" class="text-bg-danger"></span>

                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="@Model.Hours" class="form-label fw-semibold text-dark">Credit Hours</label>
                                <input type="number" asp-for="@Model.Hours" class="form-control form-control-lg" placeholder="e.g., 30" required />
                                <span asp-validation-for="@Model.Hours" class="text-bg-danger"></span>

                            </div>
                        </div>

                        <!-- Department Selection -->
                        <hr class="my-4">
                        <div class="section-divider mb-4">
                            <h5 class="fw-bold text-dark mb-3">
                                <i class="bi bi-building" style="color: #667eea;"></i> Department Assignment
                            </h5>

                            <div class="mb-3">
                                <label class="form-label fw-semibold text-dark">Select Department</label>
                                <select class="form-select form-select-lg" 
                                        asp-items="depOptions" 
                                        asp-for="@Model.Dept_Id"
                                        required>
                                    <option value="0" disabled selected>--Select Department--</option>
                                </select>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <hr class="my-4">
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="/Course/Index" class="btn btn-outline-secondary btn-lg px-5">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg px-5">
                                <i class="bi bi-plus-circle"></i> Add Course
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>


</div>

<style>
    .form-label {
        color: #333 !important;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
    }

    .form-control-lg,
    .form-select-lg {
        padding: 0.75rem 1rem;
        font-size: 1rem;
    }

    .section-divider {
        padding: 1rem 0;
    }

    .card-header {
        border-radius: 0.5rem 0.5rem 0 0 !important;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        transition: all 0.3s ease;
    }

    .btn-primary:hover {
        background: linear-gradient(135deg, #5568d3 0%, #653a8a 100%);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }

    .btn-outline-secondary:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(108, 117, 125, 0.25);
    }
</style>